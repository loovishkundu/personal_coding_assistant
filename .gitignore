# --- Python ---
__pycache__/
*.py[oc]
*$py.class
build/
dist/
wheels/
*.egg-info
*.egg

# --- Virtual environments ---
# Glob, not a literal name: macOS Finder/iCloud can create duplicates like
# ".venv 2", which a bare ".venv" pattern would NOT match (learned in maxim).
.venv*/
venv/
env/

# --- uv ---
# uv.lock IS committed for reproducibility; only ignore local cache artifacts.
.uv-cache/

# --- Secrets & environment variables ---
# PCA talks to a local LLM server and needs no API key, but never let a real
# secret slip in regardless.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
secrets.*
credentials.json
token.json
*.token

# --- Testing & tooling caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# --- Local model / runtime artifacts ---
*.gguf
models/
logs/
*.log

# --- IDE / editor ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db
